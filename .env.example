# Copy this file to .env.local and fill in real values.
# Real values live ONLY in .env.local (git-ignored) and the Vercel dashboard — never commit them.
#
# DevEx Command Center shares the Supabase project with AgileRadar but uses
# an isolated PostgreSQL schema (`devex`). AgileRadar owns `public`.

# Supabase project URL (e.g. https://xxxxxxxx.supabase.co) — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anonymous/public key — safe to expose to the browser (RLS enforces access).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# PostgreSQL schema for DevEx tables (must match migration + exposed schemas in dashboard).
NEXT_PUBLIC_SUPABASE_SCHEMA=devex

# Supabase service-role key — SERVER ONLY. Never prefix with NEXT_PUBLIC_. Never send to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Deploy script credentials (server/local only — pick one):
# Management API token: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=
# Or direct Postgres password: Dashboard → Project Settings → Database
SUPABASE_DB_PASSWORD=

# Force in-memory seed (skip Supabase reads): DATA_SOURCE=memory
